<Window
    x:Class="Mio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Mio.Controls"
    Title="Mio">

    <Grid
        x:Name="RootGrid"
        AllowDrop="True"
        Background="#050505"
        IsTabStop="True"
        DragOver="RootGrid_DragOver"
        Drop="RootGrid_Drop"
        KeyDown="RootGrid_KeyDown"
        PointerMoved="RootGrid_PointerMoved"
        PointerPressed="RootGrid_PointerPressed"
        PointerWheelChanged="RootGrid_PointerWheelChanged">

        <SwapChainPanel
            x:Name="VideoPanel"
            DoubleTapped="VideoPanel_DoubleTapped"
            SizeChanged="VideoPanel_SizeChanged" />

        <Grid x:Name="IdleLayer" IsHitTestVisible="False">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
                <TextBlock
                    x:Name="IdleTitle"
                    HorizontalAlignment="Center"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="#F2FFFFFF"
                    Text="Drop video here" />
                <TextBlock
                    x:Name="StatusText"
                    HorizontalAlignment="Center"
                    FontSize="13"
                    Foreground="#99FFFFFF"
                    Text="No media" />
                <TextBlock
                    x:Name="ErrorText"
                    MaxWidth="760"
                    HorizontalAlignment="Center"
                    FontSize="13"
                    Foreground="#FFFF8A8A"
                    TextAlignment="Center"
                    TextWrapping="Wrap"
                    Visibility="Collapsed" />
            </StackPanel>
        </Grid>

        <controls:PlayerOverlay x:Name="Overlay" />
    </Grid>
</Window>
